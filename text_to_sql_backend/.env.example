# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
# All keys are optional except where noted; defaults live in config/settings.py.

# --- Data location (optional) ---------------------------------------------
# Where the SQLite database is stored. Defaults to the OS per-user data dir
# (<user-data>/PGAIAssistant/data). Use "./data" for a repo-local dev database.
# DATA_DIR=./data

# --- Auth (REQUIRED in production) ----------------------------------------
# Generate strong random values, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=change-this-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Encryption (REQUIRED in production) ----------------------------------
# Rotating DATA_ENCRYPTION_KEY invalidates already-encrypted DB credentials.
DATA_ENCRYPTION_KEY=change-this-data-encryption-key
DB_CONNECTION_TOKEN_SECRET=change-this-shared-secret-with-mcp
DB_CONNECTION_TOKEN_TTL_SECONDS=3600

# --- MCP server -----------------------------------------------------------
MCP_SERVER_URL=http://localhost:8020/mcp

# --- Email (password-reset link delivery via Gmail SMTP) ------------------
# SMTP_PASSWORD must be a Gmail "App Password" (requires 2-Step Verification):
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=you@example.com
SMTP_FROM_NAME=PG AI Assistant

# --- Frontend / server ----------------------------------------------------
FRONTEND_BASE_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
HOST=0.0.0.0
PORT=8010
CORS_ORIGINS=http://localhost:5173
